<MudPaper Class="pa-8 d-flex flex-column align-center justify-center" Elevation="0" Outlined="true">
    <MudIcon Icon="@Icone" Size="Size.Large" Color="Color.Secondary" Class="mb-3" />
    <MudText Typo="Typo.h6" Align="Align.Center">@Titulo</MudText>
    @if (!string.IsNullOrWhiteSpace(Descricao))
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="mt-2">@Descricao</MudText>
    }
    @if (Acao is not null)
    {
        <div class="mt-4">@Acao</div>
    }
</MudPaper>

@code {
    [Parameter, EditorRequired] public string Titulo { get; set; } = string.Empty;
    [Parameter] public string? Descricao { get; set; }
    [Parameter] public string Icone { get; set; } = Icons.Material.Filled.Inbox;
    [Parameter] public RenderFragment? Acao { get; set; }
}

