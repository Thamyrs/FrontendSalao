<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@Titulo</MudText>
    </TitleContent>
    <DialogContent>
        <MudText>@Mensagem</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar">Cancelar</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="Confirmar">Excluir</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string Titulo { get; set; } = "Confirmar exclusão";
    [Parameter] public string Mensagem { get; set; } = "Deseja realmente excluir este registro?";

    private void Cancelar() => MudDialog.Cancel();
    private void Confirmar() => MudDialog.Close(DialogResult.Ok(true));
}

