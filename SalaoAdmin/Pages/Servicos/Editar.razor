@page "/servicos/editar/{Id:guid}"
@layout AdminLayout
@inject IServicoCatalogoServico ServicoCatalogoServico
@inject ICategoriaServico CategoriaServico
@inject IServicoValidacao Validacao
@inject IServicoNotificacao Notificacoes
@inject NavigationManager Navegacao

<CabecalhoPagina Titulo="Editar serviço" />

@if (_carregando)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_modelo is null)
{
    <MudAlert Severity="Severity.Warning">Serviço não encontrado.</MudAlert>
}
else
{
    <MudPaper Class="pa-4" Elevation="1" Style="position: relative;">
        <OverlayCarregando Visivel="_salvando" />
        <ServicoForm Modelo="_modelo" Categorias="_categorias" Erros="_erros" />
        <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2" Class="mt-4">
            <MudButton Variant="Variant.Text" OnClick="@(() => Navegacao.NavigateTo("/servicos"))">Cancelar</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Salvar" Disabled="_salvando">Atualizar</MudButton>
        </MudStack>
    </MudPaper>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private ServicoEdicaoDto? _modelo;
    private List<CategoriaDto> _categorias = [];
    private Dictionary<string, string> _erros = new();
    private bool _carregando = true;
    private bool _salvando;

    protected override async Task OnInitializedAsync()
    {
        var cats = await CategoriaServico.ListarAsync(new FiltroPaginacao { Pagina = 1, ItensPorPagina = 100 });
        if (cats.Sucesso && cats.Dados is not null)
            _categorias = cats.Dados.Itens.ToList();

        var resposta = await ServicoCatalogoServico.ObterPorIdAsync(Id);
        if (resposta.Sucesso && resposta.Dados is not null)
        {
            var s = resposta.Dados;
            _modelo = new ServicoEdicaoDto
            {
                Id = s.Id,
                Nome = s.Nome,
                DuracaoMinutos = s.DuracaoMinutos,
                PrecoMinimo = s.PrecoMinimo,
                CategoriaId = s.CategoriaId,
                Status = s.Status
            };
        }
        _carregando = false;
    }

    private async Task Salvar()
    {
        if (_modelo is null) return;

        var validacao = await Validacao.ValidarAsync(_modelo);
        if (!validacao.IsValid)
        {
            _erros = Validacao.ParaErros(validacao);
            return;
        }

        _salvando = true;
        try
        {
            var resposta = await ServicoCatalogoServico.AtualizarAsync(_modelo);
            if (resposta.Sucesso)
            {
                Notificacoes.Sucesso(resposta.Mensagem ?? "Atualizado.");
                Navegacao.NavigateTo("/servicos");
            }
            else
                Notificacoes.Erro(resposta.Mensagem ?? "Erro ao atualizar.");
        }
        finally
        {
            _salvando = false;
        }
    }
}
